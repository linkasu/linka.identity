# Local placeholders only. Keep each workload token and key independent.
POSTGRES_PASSWORD=replace-with-a-local-password
DATABASE_URL=postgres://identity:replace-with-the-same-local-password@postgres:5432/identity?sslmode=disable
DEPLOYMENT_ENVIRONMENT=development
WORKLOADS_JSON=[{"id":"plays-local","token":"replace-with-at-least-32-random-characters","roles":["product"],"products":["linka-plays"]},{"id":"email-verifier-local","token":"replace-with-a-different-at-least-32-random-characters","roles":["email_verifier"],"products":["linka-plays"]},{"id":"privacy-local","token":"replace-with-another-at-least-32-random-characters","roles":["privacy_admin","privacy_global"],"products":[]}]
PRODUCTS_JSON={"linka-plays":{"telemetry_audience":"linka-plays-metric"}}
PAIRWISE_ID_KEY_BASE64=replace-with-base64-of-32-random-bytes
EMAIL_KEY_PROVIDER=local
EMAIL_LOCAL_KEKS_JSON={"local-development-kek":"replace-with-base64-of-32-random-bytes"}
EMAIL_KEY_ACTIVE_ID=local-development-kek
BLIND_INDEX_KEYS_JSON={"1":"replace-with-base64-of-at-least-32-random-bytes"}
BLIND_INDEX_CURRENT_VERSION=1
TOKEN_SIGNING_KEYS_JSON={"local-development-signing-key":"replace-with-base64-of-32-random-bytes"}
TOKEN_ACTIVE_KEY_ID=local-development-signing-key
TOKEN_ISSUER=http://localhost:8080
TOKEN_TTL=5m
TOKEN_MAX_TTL=15m
MINOR_CROSS_PRODUCT_LINKING_ENABLED=false
REQUIRE_OUTBOX_DELIVERY=false
OUTBOX_POLL_INTERVAL=2s
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_READINESS_MAX_AGE=5m
EMAIL_VERIFICATION_TTL=15m
EMAIL_VERIFICATION_CLEANUP_INTERVAL=1m
# OUTBOX_DELIVERY_URL=https://plays-metric.example.test/v2/privacy/requests

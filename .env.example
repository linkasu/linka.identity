# Local placeholders only. Keep each workload token and key independent.
DEPLOYMENT_ENVIRONMENT=development
YDB_ENDPOINT=grpc://127.0.0.1:2136
YDB_DATABASE=/local
YDB_ANONYMOUS_CREDENTIALS=1
WORKLOADS_JSON=[{"id":"products-local","token":"replace-with-at-least-32-random-characters","roles":["product"],"products":["linka-plays","linka-looks","linka-pictures","linka-type","linka-paperboard","linka-site","linka-tts"]},{"id":"email-verifier-local","token":"replace-with-a-different-at-least-32-random-characters","roles":["email_verifier"],"products":["linka-plays","linka-looks","linka-pictures","linka-type","linka-paperboard","linka-site","linka-tts"]},{"id":"privacy-local","token":"replace-with-another-at-least-32-random-characters","roles":["privacy_admin","privacy_global"],"products":[]}]
PRODUCTS_JSON={"linka-plays":{"telemetry_audience":"linka-plays-metric"},"linka-looks":{"telemetry_audience":"linka-looks-metric"},"linka-pictures":{"telemetry_audience":"linka-pictures-metric"},"linka-type":{"telemetry_audience":"linka-type-metric"},"linka-paperboard":{"telemetry_audience":"linka-paperboard-metric"},"linka-site":{"telemetry_audience":"linka-site-metric"},"linka-tts":{"telemetry_audience":"linka-tts-metric"}}
PAIRWISE_ID_KEY_BASE64=replace-with-base64-of-32-random-bytes
EMAIL_KEY_PROVIDER=local
EMAIL_LOCAL_KEKS_JSON={"local-development-kek":"replace-with-base64-of-32-random-bytes"}
EMAIL_KEY_ACTIVE_ID=local-development-kek
BLIND_INDEX_KEYS_JSON={"1":"replace-with-base64-of-at-least-32-random-bytes"}
BLIND_INDEX_CURRENT_VERSION=1
TOKEN_SIGNING_KEYS_JSON={"local-development-signing-key":"replace-with-base64-of-32-random-bytes"}
TOKEN_ACTIVE_KEY_ID=local-development-signing-key
TOKEN_ISSUER=http://localhost:8080
TOKEN_TTL=5m
TOKEN_MAX_TTL=15m
MINOR_CROSS_PRODUCT_LINKING_ENABLED=false
REQUIRE_OUTBOX_DELIVERY=false
OUTBOX_POLL_INTERVAL=2s
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_READINESS_MAX_AGE=5m
EMAIL_VERIFICATION_TTL=15m
EMAIL_VERIFICATION_CLEANUP_INTERVAL=1m
